# ── Pterodactyl ───────────────────────────────────────────────────────────────
PTERO_URL=https://your-panel.example.com
PTERO_API_KEY=ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PTERO_SERVER_ID=e4b4246c

# ── Telegram (MTProto user account) ───────────────────────────────────────────
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# ── Telegram session (paste here after first login to skip OTP on redeploy) ──
# Run the bot once, complete OTP, copy the session string from the logs,
# then set this variable in Render dashboard so restarts don't need OTP again.
TELEGRAM_SESSION=

# ── Backup interval (default: 300 = 5 minutes) ────────────────────────────────
BACKUP_INTERVAL_SEC=300

# ── HTTP port for OTP entry page and status (Render sets PORT automatically) ──
PORT=8080
